      result: '캠페인 참여 학생 수 역대 최대치를 달성하는 데 기여하였으며, 직관적이면서 감성을 건드리는 비주얼 콘텐츠가 행동의 변화를 불러올 수 있음을 증명했습니다.',
      lesson: [
        '사용자들의 감수성을 자극하고 마음을 움직이는 것이 비주얼 기획의 시작이며, 좋은 카피와 조화로운 색감이 전달하는 심리적 영향력을 배운 소중한 경험이었습니다.'
      ]
    }
  }
};

// --- Navigation State ---
let currentFolderId = 'overview';
const navigationHistory = ['overview'];
let historyIndex = 0;
let currentViewType = 'grid'; // 'grid' or 'list'
let searchQuery = '';

// --- Initial Setup and Event Listeners ---
document.addEventListener('DOMContentLoaded', () => {
  renderFinderWorkspace();
  setupDraggable(document.getElementById('finder-window'));
  updateLiveClock();
  setInterval(updateLiveClock, 60000); // refresh every min
  
  // Highlighting active states
  updateNavigationButtons();
});

// --- Window Dragging Logic (Vanilla JS) ---
function setupDraggable(el) {
  if (!el) return;
  const titlebar = el.querySelector('.window-titlebar');
  if (!titlebar) return;
  
  let pos1 = 0, pos2 = 0, pos3 = 0, pos4 = 0;
  
  titlebar.onmousedown = dragMouseDown;
  titlebar.ontouchstart = dragMouseDown; // support mobile touch
  
  function dragMouseDown(e) {
    e = e || window.event;
    // Don't drag if clicking buttons
    if (e.target.closest('.control-btn')) return;
    
    // Focus window
    setActiveWindow(el);
    
    // Get cursor pos
    if (e.type === 'touchstart') {
      pos3 = e.touches[0].clientX;
      pos4 = e.touches[0].clientY;
      document.ontouchend = closeDragElement;
      document.ontouchmove = elementDrag;
    } else {
      pos3 = e.clientX;
      pos4 = e.clientY;
      document.onmouseup = closeDragElement;
      document.onmousemove = elementDrag;
    }
  }
  
  function elementDrag(e) {
    e = e || window.event;
    
    let clientX, clientY;
    if (e.type === 'touchmove') {
      clientX = e.touches[0].clientX;
      clientY = e.touches[0].clientY;
    } else {
      clientX = e.clientX;
      clientY = e.clientY;
    }
    
    pos1 = pos3 - clientX;
    pos2 = pos4 - clientY;
    pos3 = clientX;
    pos4 = clientY;
    
    // Calculate new position
    let newTop = el.offsetTop - pos2;
    let newLeft = el.offsetLeft - pos1;
    
    // Constrain inside bounds
    const maxTop = window.innerHeight - 80;
    const maxLeft = window.innerWidth - 100;
    if (newTop < 25) newTop = 25; // below menu bar
    if (newTop > maxTop) newTop = maxTop;
    if (newLeft < -100) newLeft = -100;
    if (newLeft > maxLeft) newLeft = maxLeft;
    
    el.style.top = newTop + "px";
    el.style.left = newLeft + "px";
  }
  
  function closeDragElement() {
    document.onmouseup = null;
    document.onmousemove = null;
    document.ontouchend = null;
    document.ontouchmove = null;
  }
}

// Bring active window to front
function setActiveWindow(el) {
  // Reset all windows active styles
  document.querySelectorAll('.mac-window').forEach(win => {
    win.classList.remove('active');
  });
  
  // Set active style
  el.classList.add('active');
  
  // Calculate highest z-index
  const windows = Array.from(document.querySelectorAll('.mac-window'));
  let maxZ = 10;
  windows.forEach(win => {
    const z = parseInt(window.getComputedStyle(win).zIndex) || 10;
    if (z > maxZ) maxZ = z;
  });
  
  el.style.zIndex = maxZ + 1;
}

// --- Dynamic Workspace Rendering ---
function renderFinderWorkspace() {
  const workspace = document.getElementById('finder-workspace');
  if (!workspace) return;
  workspace.innerHTML = '';
  
  // Get items under current folder
  const currentFolder = fileSystem[currentFolderId];
  let itemsToRender = [];
  
  if (currentFolder && currentFolder.children) {
    itemsToRender = currentFolder.children.map(id => ({ id, ...fileSystem[id] }));
  } else if (currentFolderId === 'overview') {
    // Top overview items
    itemsToRender = ['about_me', 'skills_motto', 'projects', 'activities', 'vision'].map(id => ({ id, ...fileSystem[id] }));
  } else {
    // Single page/project detailed landing inside Finder directly
    const selectedItem = fileSystem[currentFolderId];
    if (selectedItem && (selectedItem.type === 'project' || selectedItem.type === 'file')) {
      renderItemDetails(workspace, selectedItem);
      return;
    }
  }
  
  // Apply Search query filter if any
  if (searchQuery) {
    const query = searchQuery.toLowerCase();
    itemsToRender = itemsToRender.filter(item => 
      item.name.toLowerCase().includes(query) || 
      (item.title && item.title.toLowerCase().includes(query))
    );
  }
  
  if (itemsToRender.length === 0) {
    workspace.innerHTML = `
      <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; color: var(--text-secondary); font-size: 13px;">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-bottom: 8px;"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        검색 결과 또는 폴더 내용이 없습니다.
      </div>
    `;
    return;
  }
  
  if (currentViewType === 'grid') {
    const gridEl = document.createElement('div');
    gridEl.className = 'files-grid';
    
    itemsToRender.forEach(item => {
      const isDir = item.type === 'dir' || item.type === 'project';
      const fileIconMarkup = getIconSVG(item);
      
      const fileItem = document.createElement('div');
      fileItem.className = 'file-item';
      fileItem.onclick = (e) => {
        e.stopPropagation();
        document.querySelectorAll('.file-item').forEach(i => i.classList.remove('selected'));
        fileItem.classList.add('selected');
      };
      
      fileItem.ondblclick = () => {
        if (item.type === 'dir') {
          navigateToFolder(item.id);
        } else if (item.type === 'project') {
          navigateToFolder(item.id);
        } else {
          openFile(item.id);
        }
      };
      
      fileItem.innerHTML = `
        <div class="file-icon">${fileIconMarkup}</div>
        <div class="file-name">${item.name}</div>
      `;
      gridEl.appendChild(fileItem);
    });
    
    workspace.appendChild(gridEl);
  } else {
    // List View
    const listEl = document.createElement('div');
    listEl.className = 'files-list';
    
    listEl.innerHTML = `
      <div class="list-header">
        <div>이름</div>
        <div>종류</div>
        <div>크기</div>
      </div>
    `;
    
    itemsToRender.forEach(item => {
      const typeLabel = item.type === 'dir' ? '폴더' : (item.fileType === 'pdf' ? 'PDF 문서' : 'RTF 텍스트');
      const iconMarkup = getIconSVG(item);
      
      const listItem = document.createElement('div');
      listItem.className = 'list-item';
      listItem.onclick = (e) => {
        e.stopPropagation();
        document.querySelectorAll('.list-item').forEach(i => i.classList.remove('selected'));
        listItem.classList.add('selected');
      };
      
      listItem.ondblclick = () => {
        if (item.type === 'dir') {
          navigateToFolder(item.id);
        } else if (item.type === 'project') {
          navigateToFolder(item.id);
        } else {
          openFile(item.id);
        }
      };
      
      listItem.innerHTML = `
        <div class="list-item-name">
          <div class="list-item-icon">${iconMarkup}</div>
          <span>${item.name}</span>
        </div>
        <div class="list-item-info">${typeLabel}</div>
        <div class="list-item-info">${item.size || '--'}</div>
      `;
      
      listEl.appendChild(listItem);
    });
    
    workspace.appendChild(listEl);
  }
}

// Render detailed project views inside Finder workspace
function renderItemDetails(container, item) {
  if (item.type === 'project') {
    let stepsMarkup = '';
    if (item.sections.process && Array.isArray(item.sections.process)) {
      stepsMarkup = item.sections.process.map(s => `
        <div class="timeline-step">
          <div class="step-num">${s.step}</div>
          <div class="step-content">
            <div class="step-title">${s.title}</div>
            <div class="step-desc">${s.desc}</div>
          </div>
        </div>
      `).join('');
    }

    let lessonsMarkup = '';
    if (item.sections.lesson && Array.isArray(item.sections.lesson)) {
      lessonsMarkup = item.sections.lesson.map(l => `<li>${l}</li>`).join('');
    }

    let metadataMarkup = '';
    for (const [key, value] of Object.entries(item.meta)) {
      let label = key;
      if (key === 'role') label = '내 역할';
      else if (key === 'context') label = '소속/과목';
      else if (key === 'award') label = '수상/성과';
      else if (key === 'location') label = '활동 지역';
      else if (key === 'period') label = '활동 기간';
      else if (key === 'agency') label = '운영 기관';

      metadataMarkup += `
        <div class="meta-group">
          <div class="meta-label">${label}</div>
          <div class="meta-value">${value}</div>
        </div>
      `;
    }

    // Showcase custom drawings/icons matching details
    let showcaseMarkup = '';
    if (item.id === 'project_pbl') {
      showcaseMarkup = `
        <div class="result-showcase">
          <div class="result-mural-frame">
            <div class="mural-placeholder">
              <span>🎨🎨🎨</span>
              춘천 봉의동 벽화 개선 완성
              <div style="font-size: 11px; margin-top: 4px; opacity: 0.7;">색으로 채우는 골목길 개선 벽화</div>
            </div>
          </div>
        </div>
      `;
    }

    container.innerHTML = `
      <div class="project-content">
        <div class="project-hero">
          <span class="project-badge">${item.tags.join(' ✦ ')}</span>
          <h1 class="project-title">${item.title}</h1>
          <p class="project-subtitle">${item.subtitle}</p>
        </div>
        
        <div class="project-details-grid">
          <div class="project-main-info">
            <div class="project-section-card">
              <div class="project-section-title">기획 의도</div>
              <p class="project-section-text">${item.sections.intention}</p>
            </div>
            
            <div class="project-section-card">
              <div class="project-section-title">진행 과정</div>
              <div class="process-timeline">${stepsMarkup}</div>
            </div>
            
            <div class="project-section-card">
              <div class="project-section-title">결과물 및 성과</div>
              <p class="project-section-text">${item.sections.result}</p>
              ${showcaseMarkup}
            </div>
            
            <div class="project-section-card">
              <div class="project-section-title">느낀 점</div>
              <ul class="meta-list" style="font-size: 13.5px; line-height: 1.6; color: #333; display: flex; flex-direction: column; gap: 10px;">
                ${lessonsMarkup}
              </ul>
            </div>
          </div>
          
          <div class="project-meta-sidebar">
            ${metadataMarkup}
          </div>
        </div>
      </div>
    `;
  } else {
    // Normal file rendering in workspace (e.g. vision or about_me)
    container.innerHTML = `
      <div class="textedit-body">
        ${item.content}
      </div>
    `;
  }
}

// --- Folder Navigation Mechanics ---
function navigateToFolder(folderId) {
  if (!fileSystem[folderId]) return;
  
  // update history
  // If we were browsing history and navigate, slice future history
  if (historyIndex < navigationHistory.length - 1) {
    navigationHistory.splice(historyIndex + 1);
  }
  
  navigationHistory.push(folderId);
  historyIndex = navigationHistory.length - 1;
  
  currentFolderId = folderId;
  
  // reset search query on navigates
  document.getElementById('finder-search').value = '';
  searchQuery = '';
  
  updateFinderUI();
}

function sidebarNavigate(folderId) {
  // If already at folder, do nothing
  if (currentFolderId === folderId) return;
  navigateToFolder(folderId);
}

function navigateHistoryBack() {
  if (historyIndex > 0) {
    historyIndex--;
    currentFolderId = navigationHistory[historyIndex];
    updateFinderUI();
  }
}

function navigateHistoryForward() {
  if (historyIndex < navigationHistory.length - 1) {
    historyIndex++;
    currentFolderId = navigationHistory[historyIndex];
    updateFinderUI();
  }
}

function updateFinderUI() {
  // Update workspace items
  renderFinderWorkspace();
  
  // Update path/title breadcrumb
  const currentPathEl = document.getElementById('finder-current-path');
  if (currentPathEl) {
    let pathHTML = '';
    const folderIds = [];
    let temp = currentFolderId;
    
    // reconstruct path
    while (temp) {
      folderIds.unshift(temp);
      temp = fileSystem[temp].parentId;
    }
    
    folderIds.forEach((id, idx) => {
      const name = fileSystem[id].name.replace('.folder', '');
      if (idx > 0) {
        pathHTML += `<span class="finder-path-separator">›</span>`;
      }
      // make last item highlighted
      const activeClass = idx === folderIds.length - 1 ? 'style="color: var(--text-primary)"' : 'style="color: var(--text-secondary)"';
      pathHTML += `<span ${activeClass}>${name}</span>`;
    });
    
    currentPathEl.innerHTML = pathHTML;
  }
  
  // Update sidebar active items
  document.querySelectorAll('.finder-sidebar .sidebar-item').forEach(item => {
    const navId = item.getAttribute('data-nav');
    if (navId === currentFolderId) {
      item.classList.add('active');
    } else {
      item.classList.remove('active');
    }
  });
  
  // update history navigation buttons states
  updateNavigationButtons();
}

function updateNavigationButtons() {
  const backBtn = document.getElementById('nav-back-btn');
  const forwardBtn = document.getElementById('nav-forward-btn');
  
  if (backBtn) backBtn.disabled = historyIndex === 0;
  if (forwardBtn) forwardBtn.disabled = historyIndex === navigationHistory.length - 1;
}

function switchFinderView(view) {
  currentViewType = view;
  document.getElementById('view-grid-btn').classList.toggle('active', view === 'grid');
  document.getElementById('view-list-btn').classList.toggle('active', view === 'list');
  renderFinderWorkspace();
}

function handleSearch(val) {
  searchQuery = val;
  renderFinderWorkspace();
}

function filterByTag(tag) {
  // Go back to projects or activities folder and apply tag search or direct filter
  // Let's filter global system items containing this tag
  const workspace = document.getElementById('finder-workspace');
  if (!workspace) return;
  workspace.innerHTML = '';
  
  // Update navigation breadcrumb
  const currentPathEl = document.getElementById('finder-current-path');
  if (currentPathEl) {
    let tagKorean = tag === 'branding' ? '뷰티 브랜딩' : (tag === 'content' ? 'SNS 콘텐츠' : '경험/활동');
    currentPathEl.innerHTML = `<span>태그 필터</span><span class="finder-path-separator">›</span><span style="color: var(--accent-blue)">#${tagKorean}</span>`;
  }
  
  // Find all items matching tag
  const matchedItems = Object.keys(fileSystem)
    .filter(key => fileSystem[key].tags && fileSystem[key].tags.includes(tag))
    .map(key => ({ id: key, ...fileSystem[key] }));
    
  if (matchedItems.length === 0) {
    workspace.innerHTML = `<div style="padding: 24px; text-align: center; color: var(--text-secondary);">태그에 해당하는 파일이 없습니다.</div>`;
    return;
  }
  
  // Render grid list
  const gridEl = document.createElement('div');
  gridEl.className = 'files-grid';
  
  matchedItems.forEach(item => {
    const fileItem = document.createElement('div');
    fileItem.className = 'file-item';
    fileItem.onclick = (e) => {
      e.stopPropagation();
      document.querySelectorAll('.file-item').forEach(i => i.classList.remove('selected'));
      fileItem.classList.add('selected');
    };
    fileItem.ondblclick = () => {
      if (item.type === 'dir' || item.type === 'project') {
        navigateToFolder(item.id);
      } else {
        openFile(item.id);
      }
    };
    fileItem.innerHTML = `
      <div class="file-icon">${getIconSVG(item)}</div>
      <div class="file-name">${item.name}</div>
    `;
    gridEl.appendChild(fileItem);
  });
  
  workspace.appendChild(gridEl);
}

// --- Window Manager (Spawn document files in new windows) ---
function openFile(fileId) {
  const file = fileSystem[fileId];
  if (!file) return;
  
  // Check if window already exists
  const existingWin = document.getElementById(`window-${fileId}`);
  if (existingWin) {
    setActiveWindow(existingWin);
    existingWin.style.display = 'flex';
    existingWin.classList.remove('minimized');
    return;
  }
  
  // Spawn coordinates offset
  const offset = document.querySelectorAll('.mac-window').length * 20;
  const top = 120 + offset;
  const left = 200 + offset;
  
  const windowEl = document.createElement('div');
  windowEl.className = 'mac-window animate-open';
  windowEl.id = `window-${fileId}`;
  windowEl.style.cssText = `top: ${top}px; left: ${left}px; width: 620px; height: 480px;`;
  
  const title = file.name;
  
  windowEl.innerHTML = `
    <div class="window-titlebar">
      <div class="window-controls">
        <button class="control-btn close" onclick="closeWindow('${fileId}')"></button>
        <button class="control-btn minimize" onclick="minimizeWindow('${fileId}')"></button>
        <button class="control-btn maximize" onclick="toggleMaximizeWindow('${fileId}')"></button>
      </div>
      <div class="window-title">${title}</div>
    </div>
    <div class="window-content textedit-body">
      ${file.content}
    </div>
  `;
  
  // Append to container
  document.getElementById('spawned-windows-container').appendChild(windowEl);
  
  // Setup focus behavior
  windowEl.addEventListener('mousedown', () => setActiveWindow(windowEl));
  
  // Setup drag
  setupDraggable(windowEl);
  setActiveWindow(windowEl);
  
  // Update indicator dots in dock
  updateDockState(fileId, true);
}

function closeWindow(id) {
  const el = document.getElementById(`window-${id}`);
  if (el) {
    el.remove();
    updateDockState(id, false);
  }
}

function minimizeWindow(id) {
  const el = document.getElementById(`window-${id}`);
  if (el) {
    el.style.display = 'none';
  }
}

function toggleMaximizeWindow(id) {
  const el = document.getElementById(`window-${id}`);
  if (el) {
    if (el.style.width === '100vw') {
      // Restore
      el.style.width = '620px';
      el.style.height = '480px';
      el.style.top = '120px';
      el.style.left = '200px';
      el.style.borderRadius = '12px';
    } else {
      // Maximize
      el.style.width = '100vw';
      el.style.height = 'calc(100vh - 25px)';
      el.style.top = '25px';
      el.style.left = '0px';
      el.style.borderRadius = '0px';
    }
  }
}

// --- Dock Indicator management ---
function updateDockState(fileId, isRunning) {
  let dockTooltip = '';
  if (fileId === 'about_me') dockTooltip = '자기소개 (about_me.rtf)';
  else if (fileId === 'skills_motto') dockTooltip = '강점/관심사 (skills_&_motto.pdf)';
  else return;
  
  const dockItems = document.querySelectorAll('.dock-item');
  dockItems.forEach(item => {
    if (item.getAttribute('data-tooltip') === dockTooltip) {
      item.classList.toggle('running', isRunning);
    }
  });
}

// --- Finder Window self toggles ---
function closeFinder() {
  const el = document.getElementById('finder-window');
  if (el) {
    el.style.display = 'none';
    const finderDock = document.querySelector('.dock-item[data-tooltip="Finder"]');
    if (finderDock) finderDock.classList.remove('running');
  }
}

function minimizeFinder() {
  const el = document.getElementById('finder-window');
  if (el) {
    el.style.display = 'none';
  }
}

function openFinder() {
  const el = document.getElementById('finder-window');
  if (el) {
    el.style.display = 'flex';
    setActiveWindow(el);
    const finderDock = document.querySelector('.dock-item[data-tooltip="Finder"]');
    if (finderDock) finderDock.classList.add('running');
  }
}

function toggleMaximizeFinder() {
  const el = document.getElementById('finder-window');
  if (el) {
    if (el.style.width === '100vw') {
      // Restore
      el.style.width = '960px';
      el.style.height = '620px';
      el.style.top = '80px';
      el.style.left = '120px';
      el.style.borderRadius = '12px';
    } else {
      // Maximize
      el.style.width = '100vw';
      el.style.height = 'calc(100vh - 25px)';
      el.style.top = '25px';
      el.style.left = '0px';
      el.style.borderRadius = '0px';
    }
  }
}

// --- Desktop Icon Clicking Utilities ---
let lastClickedIcon = null;
function desktopIconClick(el, event) {
  event.stopPropagation();
  if (lastClickedIcon) {
    lastClickedIcon.classList.remove('selected');
  }
  el.classList.add('selected');
  lastClickedIcon = el;
}

// Deselect when clicking on canvas background
document.addEventListener('click', () => {
  if (lastClickedIcon) {
    lastClickedIcon.classList.remove('selected');
    lastClickedIcon = null;
  }
});

// --- Menu Bar Live Clock ---
function updateLiveClock() {
  const timeEl = document.getElementById('live-time');
  if (!timeEl) return;
  const now = new Date();
  
  // Format: "MM월 DD일 (요일) 오전/오후 HH:MM" in Korean
  const days = ['일', '월', '화', '수', '목', '금', '토'];
  const month = now.getMonth() + 1;
  const date = now.getDate();
  const day = days[now.getDay()];
  
  let hours = now.getHours();
  const ampm = hours >= 12 ? '오후' : '오전';
  hours = hours % 12;
  hours = hours ? hours : 12; // 0 should be 12
  
  const minutes = now.getMinutes().toString().padStart(2, '0');
  
  timeEl.textContent = `${month}월 ${date}일 (${day}) ${ampm} ${hours}:${minutes}`;
}

// --- SVG Icons Provider helper ---
function getIconSVG(item) {
  if (item.type === 'dir' || item.type === 'project') {
    // Blue Folder SVG
    return `
      <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M4 14C4 10.6863 6.68629 8 10 8H22C24.4795 8 26.7417 9.35825 27.8767 11.5283L29.1233 13.9117C29.6908 14.9968 30.822 15.6757 32.0409 15.6757H54C57.3137 15.6757 60 18.362 60 21.6757V50C60 53.3137 57.3137 56 54 56H10C6.68629 56 4 53.3137 4 50V14Z" fill="url(#folderGrad)"/>
        <path d="M4 20C4 17.7909 5.79086 16 8 16H56C58.2091 16 60 17.7909 60 20V50C60 53.3137 57.3137 56 54 56H10C6.68629 56 4 53.3137 4 50V20Z" fill="url(#folderFrontGrad)"/>
      </svg>
    `;
  }
  
  if (item.fileType === 'pdf') {
    // PDF Document SVG
    return `
      <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="8" y="4" width="48" height="56" rx="6" fill="#FFFFFF" stroke="#E5E5EA" stroke-width="2"/>
        <path d="M42 4H56V18L42 4Z" fill="#FF3B30"/>
        <rect x="16" y="28" width="32" height="4" rx="2" fill="#FF3B30"/>
        <text x="18" y="22" fill="#FF3B30" font-family="Arial" font-size="10" font-weight="900">PDF</text>
        <rect x="16" y="38" width="32" height="2" rx="1" fill="#8E8E93"/>
        <rect x="16" y="44" width="24" height="2" rx="1" fill="#C7C7CC"/>
      </svg>
    `;
  }
  
  // Default RTF/txt text file
  return `
    <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="8" y="4" width="48" height="56" rx="6" fill="#FFFFFF" stroke="#E5E5EA" stroke-width="2"/>
      <path d="M42 4H56V18L42 4Z" fill="#E5E5EA"/>
      <rect x="16" y="24" width="32" height="4" rx="2" fill="#ffaab9"/>
      <rect x="16" y="34" width="32" height="3" rx="1.5" fill="#8E8E93"/>
      <rect x="16" y="42" width="24" height="3" rx="1.5" fill="#8E8E93"/>
      <rect x="16" y="50" width="16" height="3" rx="1.5" fill="#C7C7CC"/>
    </svg>
  `;
}

</script>
</body>
</html>

